{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/packages/cli/schema.json",
  "productName": "Snatch Companion",
  "version": "0.1.0",
  "identifier": "com.snatch.companion",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Snatch",
        "width": 420,
        "height": 520,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "tooltip": "Snatch Companion"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "externalBin": ["binaries/yt-dlp"]
  }
}
