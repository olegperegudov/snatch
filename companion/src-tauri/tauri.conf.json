{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snatch",
  "version": "0.5.1",
  "identifier": "com.snatch.companion",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Snatch",
        "width": 400,
        "height": 450,
        "resizable": true,
        "center": true,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFQTY1QUM4MDYxQzVGRjAKUldUd1h4d0d5RnFtdm1xakNNY0RFOHNLak5BS0VDWGFaR2hUbGZoU3ZTelowQ2p6eGJ5bUUycmoK",
      "endpoints": [
        "https://github.com/olegperegudov/snatch/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "externalBin": ["binaries/yt-dlp"]
  }
}
