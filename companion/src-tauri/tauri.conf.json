{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/packages/cli/schema.json",
  "productName": "Snatch",
  "version": "0.4.0",
  "identifier": "com.snatch.companion",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "externalBin": ["binaries/yt-dlp"]
  }
}
